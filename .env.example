# ---------------------------------------------------------------------------
# 9UP Games site configuration. Copy to ".env" and fill in. Never commit .env.
# ---------------------------------------------------------------------------

# Port the HTTP server listens on.
PORT=3000

# Bind address. 127.0.0.1 if you put nginx/caddy in front (recommended),
# or 0.0.0.0 to listen on all interfaces.
HOST=127.0.0.1

# --- Editing mode -----------------------------------------------------------
# The secret that unlocks edit mode by visiting /edit/<EDIT_SECRET>.
# Choose something long and random. Rotate by changing this value and
# restarting the service (this also invalidates existing edit sessions if
# SESSION_SECRET is derived from it).
EDIT_SECRET=change-me-to-a-long-random-string

# Key used to sign the edit-session cookie. If left blank it is derived from
# EDIT_SECRET. Set an explicit value if you want to rotate EDIT_SECRET without
# logging existing editors out, or vice-versa.
SESSION_SECRET=

# How long an unlocked edit session lasts, in hours.
SESSION_HOURS=8

# Set to "true" when serving over HTTPS so the session cookie is marked Secure.
SECURE_COOKIES=false

# --- Storage paths ----------------------------------------------------------
# Where the SQLite database file lives.
DB_PATH=./data/site.db

# Where uploaded media (originals + generated thumbnails) live.
MEDIA_DIR=./media

# Maximum upload size in megabytes (per file).
MAX_UPLOAD_MB=300

# --- Outbound email (press-kit Steam-key requests) --------------------------
# Submissions are ALWAYS persisted to SQLite first. Email is a best-effort
# notification on top. If EMAIL_PROVIDER / EMAIL_API_KEY are unset, the app
# still saves the submission and logs that email delivery is unconfigured.
#
# EMAIL_PROVIDER: one of "resend", "postmark", "sendgrid", or "" (disabled).
EMAIL_PROVIDER=
EMAIL_API_KEY=

# Where notification emails are sent (the studio inbox).
EMAIL_TO=contact@9up.games

# Verified "from" address for your provider (must be a domain you've verified).
EMAIL_FROM=noreply@9up.games
